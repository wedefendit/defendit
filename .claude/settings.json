{
  "permissions": {
    "defaultMode": "ask",
    "allow": ["Read(./**)", "Edit(./**)", "Glob(./**)", "Grep(./**)"],
    "deny": [
      "Read(//**)",
      "Edit(//**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "WebFetch"
    ],
    "ask": ["Bash(*)", "Write(*)"]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "allowedDomains": []
  }
}
